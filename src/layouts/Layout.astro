---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const pageTitle = title === "ys blog" ? title : `${title} | Just Sicp`;
---

<!doctype html>
<html lang="zh-cmn-Hans">
  <head>
    <meta charset="UTF-8" />
    <meta name="author" content="dbvc" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-S4G6FGF299"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", "G-S4G6FGF299");
    </script>
  </head>
  <body>
    <nav class="header-nav"><h2><a href="/">Just Sicp</a></h2></nav>
    <header><h1>SICP Practice</h1></header>
    <main>
      <slot />
    </main>
    <footer>
      <h2><center title="ys love vc">Made by dbvc</center></h2>
    </footer>
  </body>
</html>
