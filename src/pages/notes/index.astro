---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PlainEntryList from "../../components/PlainEntryList.astro";
import { byPubDateDesc, isPublished } from "../../lib/content";
import { noteUrl } from "../../lib/urls";

const notes = (await getCollection("notes")).filter(isPublished).sort(byPubDateDesc);
---

<BaseLayout title="Notes" description="短笔记、技术观察、读书和日常判断。">
  <section class="page-title">
    <h1>Notes</h1>
    <p>短笔记、技术观察、读书和日常判断。</p>
  </section>

  <PlainEntryList
    items={notes.map((note) => ({
      title: note.data.title,
      description: note.data.description,
      href: noteUrl(note),
      date: note.data.pubDate,
    }))}
    emptyText="No notes published yet."
  />
</BaseLayout>

