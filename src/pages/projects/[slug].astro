---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/dates";
import { contentSlug } from "../../lib/urls";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: contentSlug(project) },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.description} ogType="article">
  <article class="article">
    <a class="back-link" href="/projects.html">Projects</a>
    <header class="article-header">
      <h1>{project.data.title}</h1>
      <p class="article-description">{project.data.description}</p>
      <p class="article-meta">
        <span>{project.data.status}</span>
        {
          project.data.startDate && (
            <>
              <span aria-hidden="true"> / </span>
              <span>Started {formatDate(project.data.startDate)}</span>
            </>
          )
        }
        {
          project.data.repo && (
            <>
              <span aria-hidden="true"> / </span>
              <a href={project.data.repo} rel="noreferrer">repo</a>
            </>
          )
        }
        {
          project.data.demo && (
            <>
              <span aria-hidden="true"> / </span>
              <a href={project.data.demo} rel="noreferrer">demo</a>
            </>
          )
        }
      </p>
      {
        project.data.tags.length > 0 && (
          <p class="article-tags">
            {project.data.tags.map((tag) => (
              <span>{tag}</span>
            ))}
          </p>
        )
      }
    </header>
    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>
